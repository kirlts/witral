# ============================================
# Witral - Universal Ingestion Framework
# Environment Configuration
# ============================================
# Copy this file to .env and adjust the values as needed

# --------------------------------------------
# Ingestor Configuration (Platform-agnostic)
# --------------------------------------------
# Ingestor plugin to use (e.g., 'baileys' for WhatsApp)
# REQUIRED: You must specify an ingestor plugin
# Example plugins:
#   - baileys: npm install @whiskeysockets/baileys qrcode-terminal
#   - Add your own by implementing IngestorInterface
INGESTOR_TYPE=

# Path to store ingestor session data (plugin-specific)
INGESTOR_SESSION_PATH=./data/session

# Comma-separated list of group IDs to monitor (plugin-specific)
# Format depends on the ingestor plugin you're using
INGESTOR_ALLOWED_GROUPS=

# QR code scan timeout in milliseconds (default: 60s)
# Only applies to ingestors that use QR authentication
INGESTOR_QR_TIMEOUT=60000

# Reconnection interval in milliseconds (default: 5s)
INGESTOR_RECONNECT_INTERVAL=5000

# --------------------------------------------
# Vault Configuration
# --------------------------------------------
# Base path for generated Markdown files
VAULT_PATH=./vault

# Date format for filenames (uses date-fns format)
VAULT_DATE_FORMAT=yyyy-MM-dd

# Include YAML frontmatter in generated files
VAULT_ENABLE_FRONTMATTER=true

# --------------------------------------------
# Cloud Sync Configuration
# --------------------------------------------
# Cloud sync plugin to use (e.g., 'googledrive' for Google Drive)
# local: No cloud sync (default)
# googledrive: Google Drive sync (requires OAuth setup)
SYNC_TYPE=local

# Google Drive OAuth credentials path
# Path to OAuth credentials JSON file downloaded from Google Cloud Console
# 
# Development (default): ./data/googledrive/oauth-credentials.json
#   - File is in .gitignore, safe for local development
#   - Relative to project root
#
# Production (recommended): Use absolute path outside project directory
#   Linux/macOS: ~/.config/witral/oauth-credentials.json
#   Windows: %APPDATA%/witral/oauth-credentials.json
#   Or set via environment variable for maximum security
#
# See setup wizard for detailed instructions
GOOGLE_OAUTH_CREDENTIALS_PATH=./data/googledrive/oauth-credentials.json

# OAuth Redirect Configuration (for server deployments)
# For localhost/development, leave these unset (defaults to localhost)
# For server deployments, set these to your server's domain:
# Example:
#   OAUTH_REDIRECT_HOST=example.com
#   OAUTH_REDIRECT_PROTOCOL=https
OAUTH_REDIRECT_HOST=
OAUTH_REDIRECT_PROTOCOL=http

# --------------------------------------------
# Feedback Configuration
# --------------------------------------------
# Send confirmation messages to chat
FEEDBACK_CONFIRMATIONS=true

# Send error notifications to chat
FEEDBACK_ERRORS=true

# Minimum time between feedback messages (ms)
FEEDBACK_RATE_LIMIT=1000

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Log format: json or pretty
LOG_FORMAT=pretty

# --------------------------------------------
# Timezone Configuration
# --------------------------------------------
# System timezone (e.g., UTC, America/New_York, Europe/London)
# This affects message timestamps and date formatting
# List of valid timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# --------------------------------------------
# Memory Configuration
# --------------------------------------------
# Node.js max old space size in MB (adjust for your RAM)
# Default: 1024 MB (1GB)
# For systems with limited RAM (1GB total), use 384-512
# This value is used in NODE_OPTIONS=--max-old-space-size=${NODE_MAX_OLD_SPACE}
NODE_MAX_OLD_SPACE=1024

# --------------------------------------------
# Web Dashboard Configuration
# --------------------------------------------
# Enable web dashboard
WEB_ENABLED=true

# Web dashboard port
WEB_PORT=3000

# Web dashboard host (0.0.0.0 to listen on all interfaces)
WEB_HOST=0.0.0.0

# --------------------------------------------
# Tag File Modes Configuration
# --------------------------------------------
# Tag file mode: append, new-file
# new-file: Each message creates a new file with timestamp (default for Obsidian compatibility)
#   Example: Each "idea" message creates tags/idea_[hh-mm-ss]_[dd-mm-yyyy].md
#   In new-file mode, only CONTENT is saved (for Obsidian compatibility)
# append: All messages are added to the same file
#   Example: All "idea" messages go to tags/idea.md
TAG_FILE_MODE=new-file

# Enable dynamic titles (default: true)
# When enabled, you can specify a custom filename using: tag+separator+title+space+content
# Example: ",,idea,,Christmas buy gifts" → saves to tags/idea/Christmas.md with content "buy gifts"
# This ensures native compatibility with Obsidian and other PKM systems
TAG_DYNAMIC_TITLES=true
