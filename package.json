{
  "name": "witral",
  "version": "1.0.0",
  "description": "Universal ingestion framework to transform ephemeral messages into structured knowledge for PKM",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --exclude 'dist/**' --exclude 'node_modules/**' --exclude 'data/**' src/index.ts",
    "build": "tsc && npm run build:copy-assets",
    "build:copy-assets": "mkdir -p dist/plugins && cp src/plugins/registry.json dist/plugins/registry.json",
    "start": "node --max-old-space-size=384 dist/index.js",
    "start:dev": "NODE_ENV=development tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "plugin:install": "tsx src/cli/plugin-cli.ts install",
    "plugin:list": "tsx src/cli/plugin-cli.ts list"
  },
  "keywords": [
    "pkm",
    "personal-knowledge-management",
    "obsidian",
    "logseq",
    "markdown",
    "ingestion",
    "automation",
    "note-taking",
    "knowledge-management",
    "framework",
    "modular",
    "extensible"
  ],
  "author": "Martin Gil Oyarzún <martin.gil.o@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kirlts/witral"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "dotenv": "^16.4.5",
    "hono": "^4.11.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@hapi/boom": "^9.1.4",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "googleapis": "^169.0.0",
    "google-auth-library": "^9.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
