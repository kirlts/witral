# ============================================
# Witral - Universal Ingestion Framework
# .gitignore
# ============================================

# --------------------------------------------
# Sensitive Files (Keys, Certificates)
# --------------------------------------------
*.pem
*.key
*.crt
*.cert

# --------------------------------------------
# Environment Configuration
# --------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# --------------------------------------------
# Data Directory (User-generated content)
# --------------------------------------------
data/*
!data/.keep
vault/*
!vault/.keep

# --------------------------------------------
# Dependencies
# --------------------------------------------
node_modules/
.npm
.yarn

# --------------------------------------------
# Build Output
# --------------------------------------------
dist/
*.js.map

# --------------------------------------------
# IDE/Editor
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------
# OS Files
# --------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------
# Testing
# --------------------------------------------
coverage/
.nyc_output/

# --------------------------------------------
# Logs
# --------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------------------
# Temporary Files
# --------------------------------------------
.cache/
tmp/
temp/
*.tmp
*.temp

# --------------------------------------------
# Archive Files
# --------------------------------------------
*.tar.gz
*.tar
*.zip
*.rar
*.7z

# --------------------------------------------
# Sessions and Credentials (CRITICAL)
# --------------------------------------------
auth_info_baileys/
tokens/
credentials/
client_secret.json
token.json

# --------------------------------------------
# Google Drive OAuth tokens (user-specific)
# --------------------------------------------
vault/.google-oauth-tokens.json
data/googledrive/*.json

# --------------------------------------------
# Wizard completion flag (user-specific)
# --------------------------------------------
data/.wizard-completed

# --------------------------------------------
# Production backups (user-specific)
# --------------------------------------------
backups/
backup_*.tar.gz

# --------------------------------------------
# Website Build Artifacts
# --------------------------------------------
website/dist/
website/node_modules/
website/*.tsbuildinfo
website/vite.config.js
website/vite.config.d.ts
